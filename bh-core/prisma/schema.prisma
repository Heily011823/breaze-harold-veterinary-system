// Autor: Mateo Quintero
// Version: 0.1
// rama: 17-el registro de consultas

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================
// AUTH - BH-1: Registro base de usuarios
// Autor: ChechoGc
// ==========================================

enum UserRole {
  ADMIN
  RECEPTIONIST
  VETERINARIAN
  CLIENT
}

enum AccountStatus {
  PENDING_VERIFICATION
  PENDING_APPROVAL
  ACTIVE
  SUSPENDED
}

model User {
  id        String        @id @default(uuid())
  email     String        @unique
  password  String
  firstName String
  lastName  String
  phone     String?
  role      UserRole
  status    AccountStatus @default(PENDING_VERIFICATION)
  verificationCode          String?
  verificationCodeExpiresAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  client    Client?

  @@map("users")
}

model MedicalRecord {
  id             String   @id @default(uuid())
  petId          String
  veterinarianId String
  visitReason    String
  diagnosis      String
  currentWeight  Float
  createdAt      DateTime @default(now())
}

model Product {
  id             String   @id @default(uuid())
  name           String
  type           String
  stock          Int
  unitPrice      Float
  expirationDate DateTime
  minimumStock   Int
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

enum InvoiceStatus {
  PENDING
  PAID
  CANCELLED
}

enum InvoiceItemType {
  SERVICE
  MEDICATION
  OTHER
}

model Invoice {
  id            String        @id @default(uuid())
  appointmentId String?
  clientId      String?
  petId         String?
  subtotal      Float
  discount      Float         @default(0)
  paidAmount    Float         @default(0)
  total         Float
  balance       Float
  status        InvoiceStatus @default(PENDING)
  cancellationReason String?
  cancelledAt        DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  items         InvoiceItem[]
}

model InvoiceItem {
  id          String          @id @default(uuid())
  invoiceId   String
  description String
  type        InvoiceItemType @default(OTHER)
  quantity    Int             @default(1)
  unitPrice   Float
  total       Float
  invoice     Invoice         @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}

model Service {
  id          String   @id @default(uuid())
  name        String
  description String
  price       Float
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ==========================================
// HOSPITALIZATION - BH-25
// Autor: milerickhenaor-alt
// ==========================================

model Hospitalization {
  id             String                @id @default(uuid())
  petId          String
  veterinarianId String
  reason         String
  admissionDate  DateTime              @default(now())
  dischargeDate  DateTime?
  status         HospitalizationStatus @default(HOSPITALIZED)
  exitCondition  ExitCondition?
  notes          String?
  evolutionNotes EvolutionNote[]
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  @@index([petId])
  @@index([veterinarianId])
}

model EvolutionNote {
  id                  String          @id @default(uuid())
  hospitalizationId   String
  hospitalization     Hospitalization @relation(fields: [hospitalizationId], references: [id], onDelete: Cascade)
  veterinarianId      String
  date                DateTime        @default(now())
  temperature         Float?
  heartRate           Int?
  respiratoryRate     Int?
  weight              Float?
  clinicalObservation String
  treatment           String
  medications         String
  createdAt           DateTime        @default(now())

  @@index([hospitalizationId])
}

enum HospitalizationStatus {
  HOSPITALIZED
  DISCHARGED
}

enum ExitCondition {
  RECOVERED
  DECEASED
  TRANSFERRED
}

// ==========================================
// CLIENTS - BH-7: Gestión de clientes
// Autor: Jacobo
// ==========================================

model Client {
  id             String   @id @default(uuid())
  userId         String?  @unique
  user           User?    @relation(fields: [userId], references: [id])
  firstName      String
  lastName       String
  email          String   @unique
  phoneNumber    String
  documentNumber String   @unique
  address        String?
  city           String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("clients")
}


