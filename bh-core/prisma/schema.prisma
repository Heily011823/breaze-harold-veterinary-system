// Version: 0.1
// rama: 17-el registro de consultas

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// AUTH - BH-1
enum UserRole {
  ADMIN
  RECEPTIONIST
  VETERINARIAN
  CLIENT
}

enum AccountStatus {
  PENDING_VERIFICATION
  PENDING_APPROVAL
  ACTIVE
  SUSPENDED
}

model User {
  id                        String        @id @default(uuid())
  email                     String        @unique
  password                  String
  firstName                 String
  lastName                  String
  phone                     String?
  role                      UserRole
  status                    AccountStatus @default(PENDING_VERIFICATION)
  verificationCode          String?
  verificationCodeExpiresAt DateTime?
  createdAt                 DateTime      @default(now())
  updatedAt                 DateTime      @updatedAt
  client                    Client?
  appointments Appointment[]

  @@map("users")
}

model MedicalRecord {
  id             String   @id @default(uuid())
  petId          String
  veterinarianId String
  visitReason    String
  diagnosis      String
  currentWeight  Float
  createdAt      DateTime @default(now())
  treatments     Treatment[]  // Relación con tratamientos
}

model Treatment {
  id             String   @id @default(uuid())
  description    String
  nextVisitDate  DateTime? // Opcional (nullable)
  medicalRecordId String
  medicalRecord   MedicalRecord @relation(fields: [medicalRecordId], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now())

  @@index([medicalRecordId])
}

model Product {
  id             String   @id @default(uuid())
  name           String
  type           String
  stock          Int
  unitPrice      Float
  expirationDate DateTime
  minimumStock   Int
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

enum InvoiceStatus {
  PENDING
  PAID
  CANCELLED
}

enum InvoiceItemType {
  SERVICE
  MEDICATION
  OTHER
}

model Invoice {
  id                 String        @id @default(uuid())
  appointmentId      String?
  clientId           String?
  petId              String?
  subtotal           Float
  discount           Float         @default(0)
  paidAmount         Float         @default(0)
  total              Float
  balance            Float
  status             InvoiceStatus @default(PENDING)
  cancellationReason String?
  cancelledAt        DateTime?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  items              InvoiceItem[]
}

model InvoiceItem {
  id          String          @id @default(uuid())
  invoiceId   String
  description String
  type        InvoiceItemType @default(OTHER)
  quantity    Int             @default(1)
  unitPrice   Float
  total       Float
  invoice     Invoice         @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}

model Service {
  id String @id @default(uuid())
  name String
  description String
  price Float
  isActive Boolean @default(true)
  appointments AppointmentService[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum AppointmentStatus {
  PENDING_PAYMENT
  CONFIRMED
  CANCELLED
  COMPLETED
}

model Appointment {

  id String @id @default(uuid())

  petId String

  veterinarianId String

  pet Pet @relation(fields:[petId],references:[id])

  veterinarian User @relation(fields:[veterinarianId],references:[id])

  appointmentDate DateTime

  total Float

  status AppointmentStatus @default(PENDING_PAYMENT)

  services AppointmentService[]

  cancelReason String?

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

}

model AppointmentService {

  id String @id @default(uuid())

  appointmentId String

  serviceId String

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  service Service @relation(fields: [serviceId], references: [id])

}

// HOSPITALIZATION - BH-25 - Autor: milerickhenaor-alt
model Hospitalization {
  id             String                @id @default(uuid())
  petId          String
  veterinarianId String
  reason         String
  admissionDate  DateTime              @default(now())
  dischargeDate  DateTime?
  status         HospitalizationStatus @default(HOSPITALIZED)
  exitCondition  ExitCondition?
  notes          String?
  evolutionNotes EvolutionNote[]
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  @@index([petId])
  @@index([veterinarianId])
}

model EvolutionNote {
  id                  String          @id @default(uuid())
  hospitalizationId   String
  hospitalization     Hospitalization @relation(fields: [hospitalizationId], references: [id], onDelete: Cascade)
  veterinarianId      String
  date                DateTime        @default(now())
  temperature         Float?
  heartRate           Int?
  respiratoryRate     Int?
  weight              Float?
  clinicalObservation String
  treatment           String
  medications         String
  createdAt           DateTime        @default(now())

  @@index([hospitalizationId])
}

enum HospitalizationStatus {
  HOSPITALIZED
  DISCHARGED
}

enum ExitCondition {
  RECOVERED
  DECEASED
  TRANSFERRED
}

// CLIENTS - BH-7 - Autor: Jacobo
model Client {
  id             String   @id @default(uuid())
  userId         String?  @unique
  user           User?    @relation(fields: [userId], references: [id])
  firstName      String
  lastName       String
  email          String   @unique
  phoneNumber    String
  documentNumber String   @unique
  address        String?
  city           String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  pets           Pet[]

  @@map("clients")
}

// PETS - BH-8/BH-9 - Autor: Jacobo
enum PetStatus {
  ACTIVE
  HOSPITALIZED
  DECEASED
}

model Pet {
  id        String    @id @default(uuid())
  clientId  String
  client    Client    @relation(fields: [clientId], references: [id])
  name      String
  species   String
  breed     String
  color     String
  birthDate DateTime
  weight    Float
  status    PetStatus @default(ACTIVE)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  appointments Appointment[]

  @@map("pets")
}