model MedicalRecord {
  id               String   @id @default(uuid())
  petId            String
  veterinarianId   String
  visitReason      String
  diagnosis        String
  currentWeight    Float

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}