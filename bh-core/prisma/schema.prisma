// Version: 0.2
// Rama: Bh-17 (base) + Bh-18, Bh-19, Bh-20

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// AUTH - BH-1
enum UserRole {
  ADMIN
  RECEPTIONIST
  VETERINARIAN
  CLIENT
}

enum AccountStatus {
  PENDING_VERIFICATION
  PENDING_APPROVAL
  ACTIVE
  SUSPENDED
}

model User {
  id                        String        @id @default(uuid())
  email                     String        @unique
  password                  String
  firstName                 String
  lastName                  String
  phone                     String?
  role                      UserRole
  status                    AccountStatus @default(PENDING_VERIFICATION)
  verificationCode          String?
  verificationCodeExpiresAt DateTime?
  createdAt                 DateTime      @default(now())
  updatedAt                 DateTime      @updatedAt
  client                    Client?
  appointments              Appointment[]

  @@map("users")
}

model MedicalRecord {
  id             String   @id @default(uuid())
  petId          String
  veterinarianId String
  visitReason    String
  diagnosis      String
  currentWeight  Float
  createdAt      DateTime @default(now())
  treatments     Treatment[]
  vaccines       Vaccine[]
  prescriptions  MedicationPrescription[] // ← Agregado para BH-19
}

model Treatment {
  id              String        @id @default(uuid())
  description     String
  nextVisitDate   DateTime?
  medicalRecordId String
  medicalRecord   MedicalRecord @relation(fields: [medicalRecordId], references: [id], onDelete: Cascade)
  createdAt       DateTime      @default(now())

  @@index([medicalRecordId])
}

model Vaccine {
  id              String   @id @default(uuid())
  vaccineName     String
  applicationDate DateTime
  nextDueDate     DateTime
  medicalRecordId String
  petId           String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  medicalRecord MedicalRecord @relation(fields: [medicalRecordId], references: [id], onDelete: Cascade)
  pet           Pet           @relation(fields: [petId], references: [id], onDelete: Cascade)

  @@index([nextDueDate])
  @@index([petId])
  @@index([medicalRecordId])
}


model MedicationPrescription {
  id                String   @id @default(uuid())
  medicalRecordId   String
  productId         String?  // null si es medicamento externo
  medicineName      String   // nombre del medicamento (siempre se guarda)
  dosage            String
  duration          String
  quantityPrescribed Int
  isExternal        Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  medicalRecord MedicalRecord @relation(fields: [medicalRecordId], references: [id], onDelete: Cascade)
  product       Product?      @relation(fields: [productId], references: [id])

  @@index([medicalRecordId])
  @@index([productId])
}

// Modelo Product (inventario) - ya existente
model Product {
  id             String   @id @default(uuid())
  name           String
  type           String
  stock          Int
  unitPrice      Float
  expirationDate DateTime
  minimumStock   Int
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

