generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}


model MedicalRecord {
  id              String   @id @default(uuid())
  petId           String
  veterinarianId  String
  visitReason     String
  diagnosis       String
  currentWeight   Float
  createdAt       DateTime @default(now())
}

model Product {
  id              String   @id @default(uuid())
  name            String
  type            String
  stock           Int
  unitPrice       Float
  expirationDate  DateTime
  minimumStock    Int

  isActive        Boolean  @default(true)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}